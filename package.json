{
  "name": "iris-overlay",
  "version": "1.0.3",
  "description": "Universal AI overlay assistant for gamers. Real-time screen analysis, intelligent visual classifier and persistent memory.",
  "author": "Cáceres",
  "main": "src/main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE= && electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.0",
    "firebase": "^12.16.0",
    "groq-sdk": "^1.3.0",
    "openai": "^6.47.0",
    "screenshot-desktop": "^1.15.0",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.gamingai.overlay",
    "productName": "Iris",
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerSidebar": "assets/installer/sidebar.bmp",
      "uninstallerSidebar": "assets/installer/sidebar.bmp",
      "installerHeader": "assets/installer/header.bmp"
    },
    "publish": {
      "provider": "github",
      "owner": "rubenacc89-maker",
      "repo": "Iris",
      "releaseType": "release"
    }
  }
}
